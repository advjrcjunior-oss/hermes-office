# NEMO_GUARDRAILS_SERVER_URL=http://127.0.0.1:8000
# PIPECAT_BASE_URL=http://127.0.0.1:7860
# FIRECRAWL_API_KEY=
# CRAWL4AI_BASE_URL=http://127.0.0.1:11235
